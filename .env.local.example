# Development Supabase Cloud configuration
# Copy this file to `.env.local` for local app development against the dev project.
SUPABASE_PROJECT_REF=your-dev-project-ref
SUPABASE_URL=https://your-dev-project-ref.supabase.co
SUPABASE_ANON_KEY=your-dev-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-dev-service-role-key

# Frontend URLs for local app runtime
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Optional. Omit to use same-origin /api requests.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Optional SEO metadata
GOOGLE_SITE_VERIFICATION=
NAVER_SITE_VERIFICATION=
TWITTER_HANDLE=
